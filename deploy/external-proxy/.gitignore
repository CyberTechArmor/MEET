# Generated by install.sh / update.sh from turnserver.conf.template + .env.
# Contains the static TURN auth password — never commit.
turnserver.conf

# Generated by install.sh / update.sh from livekit.yaml.template + .env.
# When TURN is enabled, contains the TURN auth password (advertised to
# clients via LiveKit's signaling response iceServers field).
livekit.yaml

# TLS cert dir — operator-provided certs.
tls/turn.crt
tls/turn.key

# Per-deployment env file (already gitignored at repo root, but be explicit).
.env
