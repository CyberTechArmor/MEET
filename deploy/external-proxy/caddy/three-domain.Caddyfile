# MEET — three-domain Caddyfile for an EXTERNAL host Caddy.
#
# Use this layout when path-prefix routing isn't possible (e.g. the public
# entry point is shared with other apps and you can't mount MEET under one
# host). Each component gets its own subdomain.
#
# Wiring assumed:
#
#   meet.example.com         ──► <UPSTREAM_HOST>:3000   (frontend)
#   api.meet.example.com     ──► <UPSTREAM_HOST>:8080   (API)
#   livekit.meet.example.com ──► <UPSTREAM_HOST>:7880   (LiveKit signaling)
#
# UPSTREAM_HOST examples:
#   • Incus/LXC bridge:   10.x.y.z   (the container's bridge IP)
#   • Same host as MEET:  127.0.0.1
#   • Remote host:        the LAN IP of the box running MEET
# Replace the three reverse_proxy targets below before deploying.
#
# DNS: create A/AAAA records for all three names pointing at the host that
# runs Caddy.

meet.example.com {
	encode gzip zstd

	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}

	header {
		Content-Security-Policy "frame-ancestors *"
		-X-Frame-Options
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

api.meet.example.com {
	encode gzip zstd

	# Body limit raised so avatar / future recording uploads aren't
	# truncated at the proxy default.
	request_body {
		max_size 50MB
	}

	reverse_proxy 127.0.0.1:8080 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		# Admin WS lives on the same upstream; flush_interval keeps the
		# stream snappy.
		flush_interval -1
	}
}

livekit.meet.example.com {
	# LiveKit signaling — long timeouts and no buffering. Browsers connect
	# wss://livekit.meet.example.com/ directly, so no path stripping.
	reverse_proxy 127.0.0.1:7880 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		flush_interval -1
		transport http {
			keepalive 30s
			keepalive_idle_conns 10
			read_timeout 24h
			write_timeout 24h
		}
	}
}
