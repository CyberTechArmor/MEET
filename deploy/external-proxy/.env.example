# MEET — External Reverse Proxy install option
#
# Copy this file to .env in the same directory and edit the values.
# This stack ships NO TLS termination, NO ACME, NO bundled Traefik/Caddy/nginx.
# An external reverse proxy (host Caddy, host nginx, NPM, ProxyPilot, …) is
# expected to terminate TLS and forward plaintext HTTP/WS to the ports below.

# ---------------------------------------------------------------------------
# 1. Public URLs
# ---------------------------------------------------------------------------
# Choose ONE of the two layouts:
#
# (A) Single-domain (recommended). The external proxy routes by path:
#       /                 -> frontend
#       /api/*            -> API
#       /livekit/*        -> LiveKit signaling (proxy strips /livekit prefix)
#     Set only PUBLIC_BASE_URL. The defaults for the other URLs are derived.
#
#       PUBLIC_BASE_URL=https://meet.example.com
#       PUBLIC_API_URL=                 # leave blank -> ${PUBLIC_BASE_URL}/api
#       PUBLIC_LIVEKIT_URL=             # leave blank -> wss://<host>/livekit
#
# (B) Three-domain (subdomain split). Use this when your proxy doesn't do
#     path routing or when you prefer to isolate signaling on its own host.
#
#       PUBLIC_BASE_URL=https://meet.example.com
#       PUBLIC_API_URL=https://api.meet.example.com
#       PUBLIC_LIVEKIT_URL=wss://livekit.meet.example.com
#
PUBLIC_BASE_URL=https://meet.example.com
PUBLIC_API_URL=
PUBLIC_LIVEKIT_URL=

# ---------------------------------------------------------------------------
# 2. Bind address
# ---------------------------------------------------------------------------
# Every externally-routed port is published on this host address.
# MUST be reachable from the external proxy. For an LXC/Incus container with
# a host proxy on the bridge, leave this at 0.0.0.0 — the container's bridge
# IP is what the host proxy connects to.
BIND_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# 3. Service ports
# ---------------------------------------------------------------------------
# meet-frontend and meet-api are published by Docker on BIND_HOST. livekit
# runs with network_mode: host and binds these ports directly on the LXC's
# interface — Docker doesn't publish them. Either way the host reverse proxy
# reaches all four on the LXC's bridge IP.
MEET_FRONTEND_PORT=3000
MEET_API_PORT=8080
MEET_LIVEKIT_WS_PORT=7880
MEET_LIVEKIT_TCP_PORT=7881

# ---------------------------------------------------------------------------
# 4. LiveKit / WebRTC media
# ---------------------------------------------------------------------------
# WebRTC media is UDP, does NOT pass through the reverse proxy, and is bound
# directly by the host-networked livekit container on the LXC's interface
# (no Docker port publishing — publishing 10k UDP ports through docker-proxy
# inside an LXC routinely hangs the install). The host firewall must forward
# this range to the LXC. See docs/install/external-reverse-proxy.md.
LIVEKIT_UDP_PORT_RANGE_START=50000
LIVEKIT_UDP_PORT_RANGE_END=60000

# Public IPv4 of the host as seen by clients. Surfaced into LiveKit's
# rtc.node_ip so ICE candidates point at a routable address rather than the
# container's bridge IP. Leave blank to let LiveKit auto-detect via STUN
# (rtc.use_external_ip: true).
LIVEKIT_NODE_IP=

# LiveKit API credentials. CHANGE BEFORE EXPOSING TO THE INTERNET.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
