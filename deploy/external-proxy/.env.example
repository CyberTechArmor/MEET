# MEET — External Reverse Proxy install option
#
# Copy this file to .env in the same directory and edit the values.
# This stack ships NO TLS termination, NO ACME, NO bundled Traefik/Caddy/nginx.
# An external reverse proxy (host Caddy, host nginx, NPM, ProxyPilot, …) is
# expected to terminate TLS and forward plaintext HTTP/WS to the ports below.

# ---------------------------------------------------------------------------
# 1. Public URLs
# ---------------------------------------------------------------------------
# Choose ONE of the two layouts:
#
# (A) Single-domain (recommended). The external proxy routes by path:
#       /                 -> frontend
#       /api/*            -> API
#       /livekit/*        -> LiveKit signaling (proxy strips /livekit prefix)
#     Set only PUBLIC_BASE_URL. The defaults for the other URLs are derived.
#
#       PUBLIC_BASE_URL=https://meet.example.com
#       PUBLIC_API_URL=                 # leave blank -> ${PUBLIC_BASE_URL}/api
#       PUBLIC_LIVEKIT_URL=             # leave blank -> wss://<host>/livekit
#
# (B) Three-domain (subdomain split). Use this when your proxy doesn't do
#     path routing or when you prefer to isolate signaling on its own host.
#
#       PUBLIC_BASE_URL=https://meet.example.com
#       PUBLIC_API_URL=https://api.meet.example.com
#       PUBLIC_LIVEKIT_URL=wss://livekit.meet.example.com
#
PUBLIC_BASE_URL=https://meet.example.com
PUBLIC_API_URL=
PUBLIC_LIVEKIT_URL=

# ---------------------------------------------------------------------------
# 2. Bind address
# ---------------------------------------------------------------------------
# Every externally-routed port is published on this host address.
# MUST be reachable from the external proxy. For an LXC/Incus container with
# a host proxy on the bridge, leave this at 0.0.0.0 — the container's bridge
# IP is what the host proxy connects to.
BIND_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# 3. Service ports
# ---------------------------------------------------------------------------
# meet-frontend and meet-api are published by Docker on BIND_HOST. livekit
# runs with network_mode: host and binds these ports directly on the LXC's
# interface — Docker doesn't publish them. Either way the host reverse proxy
# reaches all four on the LXC's bridge IP.
MEET_FRONTEND_PORT=3000
MEET_API_PORT=8080
MEET_LIVEKIT_WS_PORT=7880
MEET_LIVEKIT_TCP_PORT=7881

# ---------------------------------------------------------------------------
# 4. LiveKit / WebRTC media
# ---------------------------------------------------------------------------
# WebRTC media is UDP, does NOT pass through the reverse proxy, and is bound
# directly by the host-networked livekit container on the LXC's interface
# (no Docker port publishing — publishing 10k UDP ports through docker-proxy
# inside an LXC routinely hangs the install). The host firewall must forward
# this range to the LXC. See docs/install/external-reverse-proxy.md.
LIVEKIT_UDP_PORT_RANGE_START=50000
LIVEKIT_UDP_PORT_RANGE_END=60000

# Public IPv4 of the host as seen by clients. Surfaced into LiveKit's
# rtc.node_ip so ICE candidates point at a routable address rather than the
# container's bridge IP. install.sh auto-detects this via ifconfig.me and
# prompts to confirm; you only need to edit it manually if you change WAN
# IPs or run somewhere ifconfig.me is unreachable.
#
# Side effect of setting it: LiveKit logs `WARN ... could not validate
# external IP ... context canceled` once at startup. That's normal — LiveKit
# tries to STUN-validate the IP, can't (your host doesn't NAT-loopback its
# own public IP), then falls back to NODE_IP from this var. The warning is
# only a problem if NODE_IP is empty AND STUN can't reach a public server,
# in which case LiveKit fails to start entirely and you'll see /livekit
# 502s and admin /api/rooms 500s. Set this to silence both.
LIVEKIT_NODE_IP=

# LiveKit API credentials.
#
# These three variables MUST agree:
#   - LIVEKIT_API_KEY / LIVEKIT_API_SECRET  →  consumed by meet-api
#   - LIVEKIT_KEYS                          →  consumed by livekit (overrides
#                                              the keys: block in livekit.yaml)
#
# Format for LIVEKIT_KEYS is "<key>: <secret>" — same key and secret as above.
# install.sh handles this for you and reuses existing values on rerun.
# If you edit by hand, change all three together or every /api/rooms call
# will fail with "Unauthorized: invalid API key".
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_KEYS=devkey: secret

# ---------------------------------------------------------------------------
# 5. meet-api persistent state
# ---------------------------------------------------------------------------
# meet-api stores API keys, webhooks, server settings, and admin credentials
# in SQLite at /data/meet.db inside the container. The compose stack mounts
# the named volume `meet-api-data` there, so state survives
# `docker compose down && up`. `docker compose down -v` WIPES this volume
# along with everything else — only do that on a deliberate reset.
#
# The path inside the container is configurable via MEET_DATA_DIR; the
# default (/data) matches the volume mount and you almost never need to
# change it. Setting it elsewhere only makes sense if you're not using the
# named volume above.

# ---------------------------------------------------------------------------
# 6. TURN — cellular / restrictive-network fallback (optional but strongly
# recommended for any deployment that supports phones)
# ---------------------------------------------------------------------------
# Cellular carriers use symmetric NAT (Carrier-Grade NAT). WebRTC's
# STUN-based hole punching does NOT work through symmetric NAT, so without
# a TURN relay your phone-on-cellular users will see signaling succeed and
# the call hang at "Connecting…" — exactly the same symptom as the
# undeployed Incus proxy device, but the wifi case works.
#
# LiveKit has a built-in TURN server. Turn it on by setting TURN_ENABLED=true
# AND providing a TLS cert at TURN_TLS_DIR/turn.crt + turn.key. The cert
# must be valid for TURN_DOMAIN (browsers refuse self-signed TURN/TLS).
#
# Cert provisioning options, in increasing order of effort:
#
#   (a) Wildcard cert you already own — copy fullchain.pem to
#       <TURN_TLS_DIR>/turn.crt and privkey.pem to turn.key, set
#       TURN_DOMAIN to the base host (e.g. meet.example.com) and skip
#       creating a separate DNS record.
#
#   (b) Dedicated cert via certbot (HTTP-01 challenge):
#         dig +short turn.meet.example.com    # DNS A record points at the host
#         certbot certonly --standalone -d turn.meet.example.com --http-01-port 80
#         cp /etc/letsencrypt/live/turn.meet.example.com/fullchain.pem \
#            deploy/external-proxy/tls/turn.crt
#         cp /etc/letsencrypt/live/turn.meet.example.com/privkey.pem \
#            deploy/external-proxy/tls/turn.key
#
#   (c) Use the same cert your reverse proxy serves for meet.example.com,
#       point TURN_DOMAIN at meet.example.com (no separate DNS record),
#       set TURN_EXTERNAL_TLS=false. Works as long as the cert is valid
#       for that exact name.
#
# After enabling, open udp/TURN_UDP_PORT, tcp/TURN_TLS_PORT, and
# udp/TURN_RELAY_RANGE_START-END on the host firewall and any cloud SG.
TURN_ENABLED=false
TURN_DOMAIN=
TURN_TLS_PORT=5349
TURN_UDP_PORT=3478
TURN_RELAY_RANGE_START=30000
TURN_RELAY_RANGE_END=32000
TURN_TLS_DIR=./tls
# TURN_EXTERNAL_TLS=true means a separate frontend (Caddy/nginx) is
# terminating TLS for TURN and forwarding plaintext TURN to LiveKit on
# TURN_TLS_PORT. Leave false for the embedded-TURN flow above.
TURN_EXTERNAL_TLS=false
